# Copy to .env and fill in.

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Pick ONE way to provide the service account key (JSON from Google Cloud):

# A) Paste the whole key as one line (wrap in single quotes). Example:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'

# B) Easiest for long JSON: base64-encode the file contents, paste here (no newlines)
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# C) Path to the downloaded .json file, OR paste the full JSON as the value (supported on serverless).
# Local (npm run dev): relative to project root, e.g.
# GOOGLE_APPLICATION_CREDENTIALS=./jackson-auto-glow-7c712329ee4a.json
# Docker: compose mounts that file to /run/secrets/google-sa.json — override host file with:
# GOOGLE_SA_FILE=./path/to/your-key.json
# GOOGLE_APPLICATION_CREDENTIALS=

# Calendar tab: column A = date, B/C/D = 10:00 / 14:00 / 16:00 (row 1 can be headers)
GOOGLE_SHEETS_CALENDAR_TAB=Booking Calendar
GOOGLE_SHEETS_HEADER_ROWS=1

# Full submissions log (same spreadsheet). Tab "Submitted Requests" with headers row A–AA (auto-written if A1 is empty; admin can POST /api/admin/write-submissions-headers).
# GOOGLE_SHEETS_SUBMISSIONS_TAB=Submitted Requests
# GOOGLE_SHEETS_SUBMISSIONS_HEADER_ROWS=1

# Year implied when column A has no year (default 2026). Set when you roll the sheet to a new year.
# SHEET_CALENDAR_YEAR=2026

# Long random string used to sign the admin session cookie
SESSION_COOKIE_SECRET=

# Password for /admin (plain text in .env only — never commit .env)
ADMIN_PASSWORD=

# API server port. Production / Docker: app + API on this port (serves dist/).
# Local dev: `npm run dev` serves the UI on 8787 (Vite) and forces the API to 8788 regardless.
PORT=8787

# --- Vercel ---
# Add the same keys in the Vercel dashboard (Environment Variables). Vercel sets VERCEL=1 automatically.
# vercel.json builds the Vite app, bundles dist/ into the serverless function, and rewrites all routes to
# api/index.mjs so /api/calendar and the rest of the Express + Google Sheets API run on the same host.
