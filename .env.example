# Copy to .env and fill in.

GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Easiest on Netlify (same pattern as many Sheets apps): email + PEM key only ---
# No JSON file needed. Use the service account email from Google Cloud + the private_key PEM.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Paste the full block including BEGIN/END lines. Netlify multiline secrets work, or one line with \n:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Alias: GOOGLE_PRIVATE_KEY (same value)
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_PRIVATE_KEY=

# Optional: UTF-8 PEM base64-encoded as a single line (no newlines in the env value)
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=

# Pick ONE *additional* method below only if you are not using email + PEM.

# A) Paste the whole service account JSON as one line (wrap in single quotes). Example:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'

# B) Base64-encode the entire .json file (one line). On Mac, copy to clipboard:
#      base64 -i jackson-auto-glow-XXXX.json | tr -d '\n' | pbcopy
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# C) Path to the downloaded .json file, OR paste the full JSON as the value (serverless).
# Local (npm run dev): relative to project root, e.g.
# GOOGLE_APPLICATION_CREDENTIALS=./jackson-auto-glow-7c712329ee4a.json
# Docker: compose mounts that file to /run/secrets/google-sa.json — override host file with:
# GOOGLE_SA_FILE=./path/to/your-key.json
# GOOGLE_APPLICATION_CREDENTIALS=

# Calendar tab: column A = date, B/C/D = 10:00 / 14:00 / 16:00 (row 1 can be headers)
GOOGLE_SHEETS_CALENDAR_TAB=Booking Calendar
GOOGLE_SHEETS_HEADER_ROWS=1

# Full submissions log (same spreadsheet). Tab "Submitted Requests" with headers row A–AA (auto-written if A1 is empty; admin can POST /api/admin/write-submissions-headers).
# GOOGLE_SHEETS_SUBMISSIONS_TAB=Submitted Requests
# GOOGLE_SHEETS_SUBMISSIONS_HEADER_ROWS=1

# Optional: rename the pending-requests worksheet (default "Requests Queue"). The API creates the tab and header row automatically when needed.
# GOOGLE_SHEETS_REQUEST_QUEUE_TAB=Requests Queue

# Year implied when column A has no year (default 2026). Set when you roll the sheet to a new year.
# SHEET_CALENDAR_YEAR=2026

# Long random string used to sign the admin session cookie
SESSION_COOKIE_SECRET=

# Password for /admin (plain text in .env only — never commit .env)
ADMIN_PASSWORD=

# API server port. Production / Docker: app + API on this port (serves dist/).
# Local dev: `npm run dev` serves the UI on 8787 (Vite) and forces the API to 8788 regardless.
PORT=8787

# --- Vercel ---
# Dashboard → Settings → Environment Variables. Vercel sets VERCEL=1 automatically.
# Prefer GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY, or JSON_BASE64 if you like.
# Also set: GOOGLE_SHEETS_SPREADSHEET_ID, SESSION_COOKIE_SECRET, ADMIN_PASSWORD (and optional tab overrides).
# vercel.json: build → dist/, api/[[...path]].mjs for /api/*, SPA fallback for non-api paths.

# --- Netlify ---
# netlify.toml: publish dist/, redirect /api/* → serverless function netlify/functions/api.mjs (Express).
#
# AWS Lambda (Netlify functions) hard limit: ALL env vars together must stay under ~4KB.
# Do NOT set both GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 and GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY — pick ONE:
#   • Smallest footprint: GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY only
#   • OR only GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 (remove PEM if you use this)
# Plus: GOOGLE_SHEETS_SPREADSHEET_ID, ADMIN_PASSWORD, SESSION_COOKIE_SECRET (short random string).
# Env names: underscores only. Sheet id must match the URL exactly.
# After deploy, /api/health → {"ok":true}. Deploy 400 "4KB limit" = too many/large secrets.
