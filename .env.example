# Copy to .env and fill in.

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Pick ONE way to provide the service account key (JSON from Google Cloud):

# A) Paste the whole key as one line (wrap in single quotes). Example:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'

# B) Best for Vercel / any host that breaks on multi-line JSON: ONE variable, ONE line, no paste drama.
#    On Mac (copies to clipboard — paste into Vercel → GOOGLE_SERVICE_ACCOUNT_JSON_BASE64):
#      base64 -i jackson-auto-glow-XXXX.json | tr -d '\n' | pbcopy
#    On Mac/Linux (print to terminal):
#      base64 -i jackson-auto-glow-XXXX.json | tr -d '\n'
#    Do NOT set GOOGLE_APPLICATION_CREDENTIALS to the key if you use this; leave that empty on Vercel.
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# C) Path to the downloaded .json file, OR paste the full JSON as the value (supported on serverless).
# Local (npm run dev): relative to project root, e.g.
# GOOGLE_APPLICATION_CREDENTIALS=./jackson-auto-glow-7c712329ee4a.json
# Docker: compose mounts that file to /run/secrets/google-sa.json — override host file with:
# GOOGLE_SA_FILE=./path/to/your-key.json
# GOOGLE_APPLICATION_CREDENTIALS=

# Calendar tab: column A = date, B/C/D = 10:00 / 14:00 / 16:00 (row 1 can be headers)
GOOGLE_SHEETS_CALENDAR_TAB=Booking Calendar
GOOGLE_SHEETS_HEADER_ROWS=1

# Full submissions log (same spreadsheet). Tab "Submitted Requests" with headers row A–AA (auto-written if A1 is empty; admin can POST /api/admin/write-submissions-headers).
# GOOGLE_SHEETS_SUBMISSIONS_TAB=Submitted Requests
# GOOGLE_SHEETS_SUBMISSIONS_HEADER_ROWS=1

# Year implied when column A has no year (default 2026). Set when you roll the sheet to a new year.
# SHEET_CALENDAR_YEAR=2026

# Long random string used to sign the admin session cookie
SESSION_COOKIE_SECRET=

# Password for /admin (plain text in .env only — never commit .env)
ADMIN_PASSWORD=

# API server port. Production / Docker: app + API on this port (serves dist/).
# Local dev: `npm run dev` serves the UI on 8787 (Vite) and forces the API to 8788 regardless.
PORT=8787

# --- Vercel ---
# Dashboard → Settings → Environment Variables. Vercel sets VERCEL=1 automatically.
# If the value box won't accept your JSON (too long, newlines, quotes): use ONLY this for the key file:
#   Name:  GOOGLE_SERVICE_ACCOUNT_JSON_BASE64
#   Value: output of:  base64 -i your-service-account.json | tr -d '\n'
# Remove or blank GOOGLE_APPLICATION_CREDENTIALS on Vercel when using BASE64 (avoid setting two key methods).
# Also set: GOOGLE_SHEETS_SPREADSHEET_ID, SESSION_COOKIE_SECRET, ADMIN_PASSWORD (and optional tab overrides).
# vercel.json: build → dist/, api/[[...path]].mjs for /api/*, SPA fallback for non-api paths.

# --- Netlify ---
# netlify.toml: publish dist/, redirect /api/* → serverless function netlify/functions/api.mjs (Express).
# Same env vars as Vercel (e.g. GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 — name must use underscores only).
# After deploy, /api/health should return {"ok":true}.
